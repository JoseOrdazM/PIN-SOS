# PIN-SOS configuration

# REQUIRED — generate with: openssl rand -hex 32
PANEL_TOKEN=change-me-to-a-32-char-minimum-token

# Server
PORT=8080

# Storage
DB_PATH=/data/pinsos.db
UPLOADS_DIR=/data/uploads
STATIC_DIR=static

# Data retention (days before closed alerts + photos are purged)
RETENTION_DAYS=30

# Rate limiting
RATE_PER_IP=5
RATE_GLOBAL=60

# Telegram (optional — app works without these but won't notify)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
